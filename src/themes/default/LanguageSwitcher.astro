---
import { getLocale } from '@/messages';
import * as m from '@/messages';
import config from '@/config';

const currentLanguage = getLocale();
const languageLabels = {
    en: 'English',
    sv: 'Svenska',
    es: 'Español',
    da: 'Dansk',
    fr: 'Français',
    nb: 'Norsk Bokmål',
    fi: 'Suomi',
    sl: 'Slovenščina',
};
const languages = config.enabledLanguages.map((lang) => ({
    code: lang,
    label: languageLabels[lang] ?? lang,
}));

const base = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname;

const withLocalePrefix = pathname.startsWith(`${base}${currentLanguage}/`)
    ? pathname
    : pathname.replace(`${base}`, `${base}${currentLanguage}/`);

const localeLinks = languages.map((lang) => ({
    ...lang,
    href: withLocalePrefix.replace(
        `${base}${currentLanguage}`,
        `${base}${lang.code}`,
    ),
}));
---

<details class="zm-language-switcher">
    <summary aria-label={m.langLabel()}>
        <i class="bi bi-globe zm-language-switcher__icon"></i>
        <span class="zm-language-switcher__current">{currentLanguage.toUpperCase()}</span>
        <i class="bi bi-chevron-down zm-language-switcher__arrow"></i>
    </summary>
    <ul class="zm-language-switcher__menu">
        {
            localeLinks.map((lang) => (
                <li>
                    <a
                        href={lang.href}
                        lang={lang.code}
                        class={currentLanguage === lang.code
                            ? 'is-active'
                            : undefined}
                    >
                        {lang.code.toUpperCase()}
                    </a>
                </li>
            ))
        }
    </ul>
</details>
